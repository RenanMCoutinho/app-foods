rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuth() { return request.auth != null; }
    function getUser() { return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)); }
    function role() { return getUser().data.role; }
    function isAdmin() { return isAuth() && role() == 'admin'; }
    function isSupervisor() { return isAuth() && role() == 'supervisor'; }
    function isMotorista() { return isAuth() && role() == 'motorista'; }

    // Usuarios: cada um lê o próprio. Admin lê tudo. Supervisor lê seus motoristas.
    match /usuarios/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin() || isSupervisor());
      allow create: if true; // criação pública no cadastro
      allow update, delete: if isAdmin() || request.auth.uid == uid;
    }

    // Empresas: supervisor cria e gerencia as suas. Motoristas leem.
    match /empresas/{id} {
      allow read: if isAuth();
      allow create: if isSupervisor() || isAdmin();
      allow update, delete: if isAdmin() || (isSupervisor() && resource.data.supervisorId == request.auth.uid);
    }

    // Locais: supervisor gerencia os seus. Motoristas leem.
    match /locais/{id} {
      allow read: if isAuth();
      allow create: if isSupervisor() || isAdmin();
      allow update, delete: if isAdmin() || (isSupervisor() && resource.data.supervisorId == request.auth.uid);
    }

    // Entregas: motorista cria as próprias. Supervisor lê/gerencia as do seu grupo. Admin lê tudo.
    match /entregas/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.motoristaId == request.auth.uid ||
        resource.data.supervisorId == request.auth.uid
      );
      allow create: if isAuth() && (isMotorista() || isSupervisor() || isAdmin());
      allow update, delete: if isAdmin() ||
        resource.data.motoristaId == request.auth.uid ||
        resource.data.supervisorId == request.auth.uid;
    }
  }
}