rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuth() { return request.auth != null; }
    function getUser() { return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)); }
    function role() { return getUser().data.role; }
    function isSelf(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() { return isAuth() && role() == 'admin'; }
    function isSupervisor() { return isAuth() && role() == 'supervisor'; }
    function isMotorista() { return isAuth() && role() == 'motorista'; }
    function motoristaCanAccessSupervisor(supervisorId) {
      return isMotorista() && (
        getUser().data.supervisorId == supervisorId ||
        (getUser().data.matrizesVinculadas != null && supervisorId in getUser().data.matrizesVinculadas)
      );
    }
    function canReadManagedMotorista() {
      return isSupervisor() &&
        resource.data.role == 'motorista' &&
        resource.data.supervisorId == request.auth.uid;
    }
    function canManageManagedMotorista() {
      return isSupervisor() &&
        resource.data.role == 'motorista' &&
        resource.data.supervisorId == request.auth.uid &&
        request.resource.data.role == resource.data.role;
    }

    // Usuarios: cada um lê o próprio. Admin lê tudo. Supervisor lê apenas motoristas vinculados.
    match /usuarios/{uid} {
      allow read: if isSelf(uid) || isAdmin() || canReadManagedMotorista();
      allow create: if isSelf(uid) &&
        request.resource.data.role == 'motorista' &&
        request.resource.data.keys().hasOnly([
          'nome', 'email', 'role', 'createdAt', 'supervisorId', 'matrizesVinculadas'
        ]);
      allow update: if isAdmin() ||
        (
          isSelf(uid) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'nome', 'email', 'empresaNome', 'empresaCnpj', 'updatedAt'
          ])
        ) ||
        (
          canManageManagedMotorista() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'supervisorId', 'matrizesVinculadas', 'updatedAt'
          ])
        );
      allow delete: if isAdmin() || isSelf(uid);
    }

    // Empresas: admin lê tudo. Supervisor gerencia as suas. Motorista lê apenas as vinculadas.
    match /empresas/{id} {
      allow read: if isAdmin() ||
        (isSupervisor() && resource.data.supervisorId == request.auth.uid) ||
        motoristaCanAccessSupervisor(resource.data.supervisorId);
      allow create: if isAdmin() ||
        (isSupervisor() && request.resource.data.supervisorId == request.auth.uid);
      allow update: if isAdmin() ||
        (
          isSupervisor() &&
          resource.data.supervisorId == request.auth.uid &&
          request.resource.data.supervisorId == resource.data.supervisorId
        );
      allow delete: if isAdmin() || (isSupervisor() && resource.data.supervisorId == request.auth.uid);
    }

    // Locais: admin lê tudo. Supervisor gerencia os seus. Motorista lê apenas os vinculados.
    match /locais/{id} {
      allow read: if isAdmin() ||
        (isSupervisor() && resource.data.supervisorId == request.auth.uid) ||
        motoristaCanAccessSupervisor(resource.data.supervisorId);
      allow create: if isAdmin() ||
        (isSupervisor() && request.resource.data.supervisorId == request.auth.uid);
      allow update: if isAdmin() ||
        (
          isSupervisor() &&
          resource.data.supervisorId == request.auth.uid &&
          request.resource.data.supervisorId == resource.data.supervisorId
        );
      allow delete: if isAdmin() || (isSupervisor() && resource.data.supervisorId == request.auth.uid);
    }

    // Entregas: motorista vê/cria as próprias. Supervisor vê/gerencia só o seu grupo. Admin lê tudo.
    match /entregas/{id} {
      allow read: if isAdmin() ||
        (isSupervisor() && resource.data.supervisorId == request.auth.uid) ||
        (isMotorista() && resource.data.motoristaId == request.auth.uid);
      allow create: if isAdmin() ||
        (
          isSupervisor() &&
          request.resource.data.supervisorId == request.auth.uid
        ) ||
        (
          isMotorista() &&
          request.resource.data.motoristaId == request.auth.uid &&
          motoristaCanAccessSupervisor(request.resource.data.supervisorId)
        );
      allow update: if isAdmin() ||
        (
          isSupervisor() &&
          resource.data.supervisorId == request.auth.uid &&
          request.resource.data.supervisorId == resource.data.supervisorId
        ) ||
        (
          isMotorista() &&
          resource.data.motoristaId == request.auth.uid &&
          request.resource.data.motoristaId == resource.data.motoristaId &&
          request.resource.data.supervisorId == resource.data.supervisorId
        );
      allow delete: if isAdmin() ||
        (isSupervisor() && resource.data.supervisorId == request.auth.uid) ||
        (isMotorista() && resource.data.motoristaId == request.auth.uid);
    }
  }
}
